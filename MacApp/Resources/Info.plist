<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleName</key>
    <string>MacKeymapper</string>
    <key>CFBundleDisplayName</key>
    <string>MacKeymapper</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0.0</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleIconFile</key>
    <string>AppIcon</string>
    <key>NSPrincipalClass</key>
    <string>NSApplication</string>
    <key>LSUIElement</key>
    <true/>
    <key>NSHighResolutionCapable</key>
    <true/>
    <key>LSMinimumSystemVersion</key>
    <string>13.0</string>
    <key>NSHumanReadableCopyright</key>
    <string>Copyright © 2025 MacLauncher. All rights reserved.</string>
    <key>SUFeedURL</key>
    <string>https://your-website.com/appcast.xml</string>
    <key>SUPublicEDKey</key>
    <string>REPLACE_WITH_SPARKLE_EDKEY</string>
    <key>NSLocalNetworkUsageDescription</key>
    <string>MacLauncher Remote uses the local network to communicate with the iOS companion app.</string>
    <key>NSBonjourServices</key>
    <array>
        <string>_maclauncher._tcp.</string>
    </array>
</dict>
</plist>
